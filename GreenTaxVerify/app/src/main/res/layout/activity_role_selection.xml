<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Header Section -->
        <TextView
            android:id="@+id/tv_role_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Select Your Role"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
            android:textStyle="bold"
            android:textColor="@color/primary" />

        <TextView
            android:id="@+id/tv_role_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Access tailored tools and dashboards based on your official responsibilities or residential status."
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <!-- Secretary Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <Button
                android:id="@+id/btn_secretary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:text="Secretary"
                android:textSize="18sp"
                android:textStyle="bold"
                style="@style/Widget.Material3.Button.TextButton" />

        </com.google.android.material.card.MaterialCardView>

        <!-- BMC Admin Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/primary"
            app:strokeWidth="0dp">

            <Button
                android:id="@+id/btn_admin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:text="BMC Admin"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                style="@style/Widget.Material3.Button.TextButton" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Resident Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <Button
                android:id="@+id/btn_resident"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:text="Resident"
                android:textSize="18sp"
                android:textStyle="bold"
                style="@style/Widget.Material3.Button.TextButton" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
